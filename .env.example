# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Helpdesk inbox(es) — comma-separated for multiple addresses
HR_HELPDESK_EMAIL=sankit@yopmail.com

# Email webhook secret (for inbound email processing)
INBOUND_EMAIL_WEBHOOK_SECRET=your_webhook_secret

# Vercel Cron secret (set in Vercel dashboard, used for due-date-reminders)
CRON_SECRET=your_cron_secret

# Optional: Mailgun inbound webhook signing key
MAILGUN_WEBHOOK_SIGNING_KEY=

# Outbound email (Resend)
# RESEND_API_KEY: API key from https://resend.com/api-keys
# Leave unset during local dev to log emails to the console instead of sending.
RESEND_API_KEY=your_resend_api_key

# Resend inbound webhook signing secret (from Resend → Webhooks → your webhook)
RESEND_WEBHOOK_SECRET=whsec_your_webhook_secret

# EMAIL_FROM controls the sender address for invites, ticket notifications, etc.
#
# Production (send to any recipient):
#   1. Verify your domain at https://resend.com/domains (add the DNS records Resend provides)
#   2. Use an address on that domain:
# EMAIL_FROM="HR Helpdesk <noreply@ebizondigital.com>"
#
# Local testing without domain verification (Resend sandbox):
#   - Use onboarding@resend.dev as the sender
#   - Recipients must be the email on your Resend account only
# EMAIL_FROM="HR Helpdesk <onboarding@resend.dev>"
EMAIL_FROM=noreply@ebizondigital.com

# Optional: Microsoft OneDrive — archive inbound email attachments (not inline signature images)
# Register an app in Azure AD with application permission Files.ReadWrite.All (admin consent required).
# MICROSOFT_TENANT_ID=your_azure_tenant_id
# MICROSOFT_CLIENT_ID=your_app_client_id
# MICROSOFT_CLIENT_SECRET=your_app_client_secret
# ONEDRIVE_USER_ID=user@yourcompany.com
# ONEDRIVE_FOLDER=HRHelpDesk/Attachments
